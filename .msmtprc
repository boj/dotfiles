defaults
port 587
auth on
tls on
tls_trust_file ~/.ca-bundle.crt

account gmail
host smtp.gmail.com
from mojobojo@gmail.com
user mojobojo@gmail.com
passwordeval gpg -q --for-your-eyes-only --no-tty -d ~/.mail/.auth1.gpg

account uncannyworks
host smtp.gmail.com
from brian.jones@uncannyworks.com
user brian.jones@uncannyworks.com
passwordeval gpg -q --for-your-eyes-only --no-tty -d ~/.mail/.auth2.gpg

account default : gmail
